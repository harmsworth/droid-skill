# =====================================================================
# Videocut 配置文件
# =====================================================================

# 火山引擎语音识别 API Key
# 获取地址: https://console.volcengine.com/speech/new/experience/asr
VOLCENGINE_API_KEY=your_api_key_here

# 可选：自定义输出目录
# OUTPUT_DIR=./output

# 可选：静音阈值（秒，默认 0.3）
# SILENCE_THRESHOLD=0.3

# 可选：重复句检测字数（默认 5）
# REPEAT_WORD_COUNT=5
